---
import { getEmDashCollection, getTermsForEntries, getSiteSettings } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";
import { getPostViewCountsForLocals } from "../../utils/post-views";
import { resolveBlogSiteIdentity } from "../../utils/site-identity";

// Sort in the database rather than in JS — lets the DB use its index on
// published_at and avoids a full-table scan on the client.
const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

// Single batched query for tags across all posts, instead of one
// getEntryTerms() call per post (which would be N round-trips).
// Bylines are already hydrated on entry.data.bylines.
const tagsByEntry = await getTermsForEntries(
	"posts",
	posts.map((p) => p.data.id),
	"tag",
);

const postsWithTags = posts.map((post) => ({
	post,
	tags: tagsByEntry.get(post.data.id) ?? [],
}));

const viewCounts = await getPostViewCountsForLocals(
	Astro.locals,
	posts.map((post) => post.data.id),
);

const { siteTagline } = resolveBlogSiteIdentity(await getSiteSettings());
---

<Base title="All Posts" description={siteTagline}>
	<div class="posts-page">
		<header class="page-header">
			<div>
				<h1 class="page-title">Todos los artículos</h1>
				<p class="page-description">
					{posts.length}
					{posts.length === 1 ? "artículo" : "artículos"}
				</p>
			</div>
			<div class="page-controls">
				<label class="sort-label">
					<span>Ordenar por</span>
					<select class="sort-select" data-sort-order>
						<option value="newest">Más reciente</option>
						<option value="oldest">Más antiguo</option>
					</select>
				</label>
			</div>
		</header>

		{
			posts.length === 0 ? (
				<p class="empty">Aún no hay artículos.</p>
			) : (
				<>
					<div class="posts-grid" data-posts-grid>
						{postsWithTags.map(({ post, tags }, index) => (
							<div
								class:list={["post-slot", index >= 6 && "is-hidden"]}
								data-post-card
								data-published-at={post.data.publishedAt?.getTime() ?? 0}
							>
								<PostCard
									title={post.data.title ?? "Untitled"}
									excerpt={post.data.excerpt}
									featuredImage={post.data.featured_image}
									href={`/posts/${post.id}`}
									date={post.data.publishedAt ?? undefined}
									readingTime={getReadingTime(post.data.content)}
									tags={tags.map((t) => ({ slug: t.slug, label: t.label }))}
									viewCount={viewCounts.get(post.data.id)}
									reveal
								/>
							</div>
						))}
					</div>
					<div class="load-sentinel" data-load-sentinel aria-hidden="true"></div>
					<p class="load-end" data-load-end hidden>
						No hay más artículos por cargar.
					</p>
				</>
			)
		}
	</div>
</Base>

<script>
	const INITIAL_VISIBLE = 6;
	const PAGE_SIZE = 6;
	const grid = document.querySelector<HTMLElement>("[data-posts-grid]");
	const sortSelect = document.querySelector<HTMLSelectElement>("[data-sort-order]");
	const sentinel = document.querySelector<HTMLElement>("[data-load-sentinel]");
	const endMessage = document.querySelector<HTMLElement>("[data-load-end]");

	if (grid && sortSelect && sentinel && endMessage) {
		const cards = Array.from(
			grid.querySelectorAll<HTMLElement>("[data-post-card]"),
		);
		let visibleCount = Math.min(INITIAL_VISIBLE, cards.length);
		let revealObserver: IntersectionObserver | null = null;

		const observeReveal = () => {
			revealObserver?.disconnect();
			revealObserver = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							entry.target.classList.add("is-visible");
							revealObserver?.unobserve(entry.target);
						}
					}
				},
				{ threshold: 0.15 },
			);

			for (const slot of cards) {
				if (slot.classList.contains("is-hidden")) continue;
				const card = slot.querySelector<HTMLElement>(".post-card.reveal");
				if (card) revealObserver.observe(card);
			}
		};

		const syncVisibility = (resetAnimation = false) => {
			cards.forEach((card, index) => {
				const shouldShow = index < visibleCount;
				card.classList.toggle("is-hidden", !shouldShow);
				if (resetAnimation) {
					card
						.querySelector<HTMLElement>(".post-card.reveal")
						?.classList.remove("is-visible");
				}
			});

			endMessage.hidden = visibleCount < cards.length;
			observeReveal();
		};

		const sortCards = (mode: "newest" | "oldest") => {
			cards.sort((a, b) => {
				const aDate = Number(a.dataset.publishedAt ?? 0);
				const bDate = Number(b.dataset.publishedAt ?? 0);
				return mode === "oldest" ? aDate - bDate : bDate - aDate;
			});
			cards.forEach((card) => grid.append(card));
			visibleCount = Math.min(INITIAL_VISIBLE, cards.length);
			syncVisibility(true);
		};

		const loadMore = () => {
			if (visibleCount >= cards.length) return;
			visibleCount = Math.min(visibleCount + PAGE_SIZE, cards.length);
			syncVisibility();
		};

		sortSelect.addEventListener("change", () => {
			sortCards(sortSelect.value === "oldest" ? "oldest" : "newest");
		});

		const scrollObserver = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						loadMore();
					}
				}
			},
			{ rootMargin: "260px 0px 260px 0px", threshold: 0 },
		);
		scrollObserver.observe(sentinel);

		sortCards("newest");
	}
</script>

<style>
	.posts-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	.page-header {
		margin-bottom: var(--spacing-10);
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-5);
		align-items: end;
		justify-content: space-between;
	}

	.page-title {
		font-size: clamp(var(--font-size-3xl), 3vw, var(--font-size-4xl));
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-2);
	}

	.page-description {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
	}

	.page-controls {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-start;
	}

	.sort-label {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
	}

	.sort-select {
		min-height: 44px;
		min-width: 190px;
		padding: var(--spacing-2) var(--spacing-3);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-bg);
		color: var(--color-text);
		font-size: var(--font-size-sm);
		font-family: var(--font-sans);
	}

	.sort-select:focus-visible {
		outline: none;
		border-color: var(--color-accent);
		box-shadow: 0 0 0 3px var(--color-accent-ring);
	}

	.empty {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--spacing-10) var(--spacing-8);
	}

	.post-slot {
		min-width: 0;
	}

	.post-slot.is-hidden {
		display: none;
	}

	.load-sentinel {
		height: 1px;
		margin-top: var(--spacing-2);
	}

	.load-end {
		margin-top: var(--spacing-8);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		text-align: center;
	}

	@media (max-width: 1024px) {
		.posts-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.posts-page {
			padding: var(--spacing-6) var(--spacing-4) var(--spacing-12);
		}

		.page-header {
			align-items: stretch;
		}

		.page-controls {
			width: 100%;
		}

		.sort-label,
		.sort-select {
			width: 100%;
		}

		.posts-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}
	}
</style>
