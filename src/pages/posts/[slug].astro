---
import {
	getEmDashEntry,
	getEmDashCollection,
	getTermsForEntries,
	getSeoMeta,
	decodeSlug,
	getSiteSettings,
} from "emdash";
import {
	Image,
	PortableText,
} from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";
import { resolveBlogSiteIdentity } from "../../utils/site-identity";
import { getPostViewCountsForLocals, incrementPostView, formatViewCount, getPostViewsKv } from "../../utils/post-views";
import RevealOnView from "../../components/RevealOnView.astro";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

// Get featured image URL for OG fallback
// The image may have src (external) or meta.storageKey (local)
function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	// Check for direct src
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	// Build from storageKey for local images
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());

// Generate SEO meta from content
const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
	defaultOgImage: featuredImageUrl,
});

// Bylines are already hydrated by getEmDashEntry
const bylines = post.data.bylines ?? [];

// Get reading time
const readingTime = getReadingTime(post.data.content);

const viewCount = await incrementPostView(
	getPostViewsKv(Astro.locals as import("../../utils/post-views").RuntimeLocals),
	post.data.id,
);

// Fetch related posts
const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});
const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);

// Single batched query for related-posts tags, rather than one
// getEntryTerms() call per related post.
const otherTagsByEntry = await getTermsForEntries(
	"posts",
	otherPosts.map((p) => p.data.id),
	"tag",
);
const otherPostsWithTags = otherPosts.map((p) => ({
	post: p,
	tags: otherTagsByEntry.get(p.data.id) ?? [],
}));

const relatedViewCounts = await getPostViewCountsForLocals(
	Astro.locals,
	otherPosts.map((p) => p.data.id),
);

const publishDate =
	post.data.publishedAt?.toLocaleDateString("es-CL", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;

const primaryByline = bylines[0] ?? null;

const avatarMap: Record<string, string> = {
	"Mila Vivanco": "/images/mila-vivanco-400.webp",
	"Isabel Martínez": "/images/isabel-martinez.jpg",
};
const authorAvatar =
	avatarMap[primaryByline?.byline.displayName ?? ""] ??
	"/images/mila-vivanco-400.webp";

const viewsLabel =
	viewCount === 1 ? "1 vista" : `${formatViewCount(viewCount)} vistas`;

/** Extrae bloques de custom_html por marcadores HTML para inyectarlos inline */
function parseCustomHtmlParts(html: string | undefined) {
	if (!html) return null;

	const styles = html.match(/<style>[\s\S]*?<\/style>/)?.[0] ?? "";

	const sliceBetween = (startMarker: string, endMarkers: string[]) => {
		const start = html.indexOf(startMarker);
		if (start === -1) return "";
		const contentStart = html.indexOf("-->", start);
		if (contentStart === -1) return "";
		const from = contentStart + 3;
		let end = html.length;
		for (const marker of endMarkers) {
			const idx = html.indexOf(marker, from);
			if (idx !== -1 && idx < end) end = idx;
		}
		return html.slice(from, end).trim();
	};

	return {
		styles,
		counters: sliceBetween("<!-- COUNTERS", [
			"<!-- GRÁFICO SEO",
			"<!-- MANIFESTO",
			"<!-- 3 EXPLAINER",
			"<!-- GRÁFICO AUTOMATIZACIÓN",
			"<!-- DANGER BOX",
			"<!-- 3 PECADOS",
			"<!-- BRAIN MAP",
			"<!-- GRÁFICO TRÁFICO",
			"<!-- GRÁFICO",
		]),
		gapHs: sliceBetween("<!-- GAP VISUALIZATION", ["<!-- COUNTERS"]),
		seoChartHs: sliceBetween("<!-- GRÁFICO SEO", ["<!-- TABLA ROI"]),
		roiTableHs: sliceBetween("<!-- TABLA ROI", ["<!-- 6 FEATURES"]),
		featuresHs: sliceBetween("<!-- 6 FEATURES", ["<!-- 4 PREGUNTAS"]),
		questionsHs: sliceBetween("<!-- 4 PREGUNTAS", ["<!-- CTA FINAL"]),
		manifestoSd: sliceBetween("<!-- MANIFESTO", ["<!-- GRÁFICO OPEX"]),
		opexChartSd: sliceBetween("<!-- GRÁFICO OPEX", ["<!-- 4 PILARES"]),
		pillarsSd: sliceBetween("<!-- 4 PILARES", ["<!-- COMPARATIVA COSTOS"]),
		costGridSd: sliceBetween("<!-- COMPARATIVA COSTOS", ["<!-- MAPA REGIONAL"]),
		regionalSd: sliceBetween("<!-- MAPA REGIONAL", ["<!-- GRÁFICO ADOPCIÓN"]),
		adopcionSd: sliceBetween("<!-- GRÁFICO ADOPCIÓN", ["<!-- CTA FINAL"]),
		explainersPy: sliceBetween("<!-- 3 EXPLAINER", ["<!-- GRÁFICO CUELLOS"]),
		bottlenecksPy: sliceBetween("<!-- GRÁFICO CUELLOS", ["<!-- 3 SOLUCIONES"]),
		solsPy: sliceBetween("<!-- 3 SOLUCIONES", ["<!-- COMPARATIVA"]),
		compPy: sliceBetween("<!-- COMPARATIVA SIN/CON", ["<!-- GRÁFICO IMPACTO"]),
		impactPy: sliceBetween("<!-- GRÁFICO IMPACTO", ["<!-- CTA FINAL"]),
		autoChart: sliceBetween("<!-- GRÁFICO AUTOMATIZACIÓN", ["<!-- 4 FASES"]),
		danger: sliceBetween("<!-- DANGER BOX", ["<!-- 4 PREGUNTAS"]),
		questions: sliceBetween("<!-- 4 PREGUNTAS", [
			"<!-- GRÁFICO VECTORES",
			"<!-- CTA FINAL",
		]),
		attackChart: sliceBetween("<!-- GRÁFICO VECTORES", ["<!-- TABLA COMPARATIVA"]),
		compareTable: sliceBetween("<!-- TABLA COMPARATIVA", ["<!-- 4 FASES"]),
		phases: sliceBetween("<!-- 4 FASES", [
			"<!-- 3 MODELOS",
			"<!-- GRÁFICO REVENUE",
		]),
		modelsF40: sliceBetween("<!-- 3 MODELOS", ["<!-- CASO ÉXITO", "<!-- GRÁFICO ROI"]),
		successCase: sliceBetween("<!-- CASO ÉXITO", ["<!-- GRÁFICO ROI"]),
		roiF40: sliceBetween("<!-- GRÁFICO ROI", [
			"<!-- CTA FINAL",
			"<!-- EMDASH BADGE",
		]),
		revProjection: sliceBetween("<!-- GRÁFICO REVENUE", [
			"<!-- EMDASH BADGE",
			"<!-- CTA FINAL",
		]),
		emdashBadge: sliceBetween("<!-- EMDASH BADGE", ["<!-- CTA FINAL"]),
		greenAlertFmc: sliceBetween("<!-- BLOQUE VERDE", ["<!-- CASO ANDES"]),
		caseAndesFmc: sliceBetween("<!-- CASO ANDES", ["<!-- 3 PECADOS", "<!-- TABLA"]),
		sins: sliceBetween("<!-- 3 PECADOS", ["<!-- TABLA PECADOS"]),
		pvTable: sliceBetween("<!-- TABLA PECADOS", [
			"<!-- GRÁFICO CORRELACIÓN",
			"<!-- GRÁFICO",
		]),
		revenueChart: sliceBetween("<!-- GRÁFICO CORRELACIÓN", [
			"<!-- 4 PASOS GROWTH",
			"<!-- GRÁFICO COMPARATIVO",
		]),
		steps: sliceBetween("<!-- 4 PASOS GROWTH", ["<!-- CTA FINAL"]),
		brainMap: sliceBetween("<!-- BRAIN MAP", ["<!-- GRÁFICO COMPARATIVO", "<!-- GRÁFICO"]),
		traffic: sliceBetween("<!-- GRÁFICO TRÁFICO", ["<!-- BLOQUE SEO vs AEO", "<!-- BLOQUE SEO"]),
		chart: sliceBetween("<!-- GRÁFICO COMPARATIVO", ["<!-- 3 MODELOS", "<!-- MODELOS"]),
		seoAeo: sliceBetween("<!-- BLOQUE SEO vs AEO", ["<!-- TERMINAL"]),
		models: sliceBetween("<!-- 3 MODELOS", ["<!-- CTA FINAL"]),
		terminal: sliceBetween("<!-- TERMINAL", ["<!-- CTA FINAL"]),
		cta: sliceBetween("<!-- CTA FINAL", []),
	};
}

const customParts = parseCustomHtmlParts(post.data.custom_html);
const contentBlocks = post.data.content ?? [];

/** Imágenes reemplazadas por bloques HTML inline */
const SKIP_CONTENT_KEYS = new Set(["img-trafico", "img-aeo"]);

/** Con indicadores: primer párrafo va antes de los counters (después del byline) */
const leadBlock =
	customParts?.counters && contentBlocks[0]?._type === "block"
		? contentBlocks[0]
		: null;
const bodyBlocks = leadBlock
	? contentBlocks.filter((block) => block._key !== leadBlock._key)
	: contentBlocks;
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	author="Mila Vivanco"
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<article class="article">
		{
			post.data.featured_image && (
				<div class="article-hero" {...post.edit.featured_image}>
					<Image image={post.data.featured_image} />
				</div>
			)
		}

		<div class="article-inner">
			{customParts?.styles && <Fragment set:html={customParts.styles} />}

			<header class="article-header">
				<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>
				{
					post.data.excerpt && (
						<p class="article-excerpt" {...post.edit.excerpt}>
							{post.data.excerpt}
						</p>
					)
				}
				<div class="article-meta-row">
					{
						primaryByline && (
							<div class="article-meta-author">
								<img
									src={authorAvatar}
									alt={primaryByline.byline.displayName}
									class="article-meta-avatar"
									width="48"
									height="48"
								/>
								<div class="byline-info">
									<span class="byline-name">
										{primaryByline.byline.displayName}
									</span>
									{primaryByline.roleLabel && (
										<span class="byline-role">
											{primaryByline.roleLabel}
										</span>
									)}
								</div>
							</div>
						)
					}
					<div class="article-meta-stats">
						{
							publishDate && (
								<span class="article-meta-stat">
									<span aria-hidden="true">📅</span>
									<time>{publishDate}</time>
								</span>
							)
						}
						<span class="article-meta-stat">
							<span aria-hidden="true">⏱</span> {readingTime}
						</span>
						<span class="article-meta-stat">
							<span aria-hidden="true">👁</span> {viewsLabel}
						</span>
					</div>
				</div>
				{
					leadBlock && (
						<div class="article-lead">
							<PortableText value={[leadBlock]} />
						</div>
					)
				}
				{
					customParts?.counters && (
						<div class="article-counters" set:html={customParts.counters} />
					)
				}
				{
					customParts?.successCase && customParts?.modelsF40 && (
						<div class="custom-html-inline" set:html={customParts.successCase} />
					)
				}
			</header>

			<div class="article-content">
				{
					customParts
						? bodyBlocks.map((block) => {
								if (SKIP_CONTENT_KEYS.has(block._key as string)) return null;
								return (
									<>
										<PortableText value={[block]} />
										{block._key === "k4" && customParts.autoChart && (
											<div class="custom-html-inline" set:html={customParts.autoChart} />
										)}
										{block._key === "k8" && customParts.seoChartHs && (
											<div class="custom-html-inline" set:html={customParts.seoChartHs} />
										)}
										{block._key === "k8" && customParts.pillarsSd && (
											<div class="custom-html-inline" set:html={customParts.pillarsSd} />
										)}
										{block._key === "k8" && customParts.phases && (
											<div class="custom-html-inline" set:html={customParts.phases} />
										)}
										{block._key === "k8" && customParts.successCase && !customParts.modelsF40 && (
											<div class="custom-html-inline" set:html={customParts.successCase} />
										)}
										{block._key === "k10" && customParts.roiTableHs && (
											<div class="custom-html-inline" set:html={customParts.roiTableHs} />
										)}
										{block._key === "k10" && customParts.opexChartSd && !customParts.costGridSd && (
											<div class="custom-html-inline" set:html={customParts.opexChartSd} />
										)}
										{block._key === "k10" && customParts.solsPy && (
											<div class="custom-html-inline" set:html={customParts.solsPy} />
										)}
										{block._key === "k10" && customParts.compPy && customParts.solsPy && (
											<div class="custom-html-inline" set:html={customParts.compPy} />
										)}
										{block._key === "k10" && customParts.modelsF40 && (
											<div class="custom-html-inline" set:html={customParts.modelsF40} />
										)}
										{block._key === "k10" && customParts.roiF40 && (
											<div class="custom-html-inline" set:html={customParts.roiF40} />
										)}
										{block._key === "k3" && customParts.greenAlertFmc && (
											<div class="custom-html-inline" set:html={customParts.greenAlertFmc} />
										)}
										{block._key === "k3" && customParts.caseAndesFmc && (
											<div class="custom-html-inline" set:html={customParts.caseAndesFmc} />
										)}
										{block._key === "k1" && !customParts.greenAlertFmc && (customParts.sins || customParts.danger) && (
											<div class="custom-html-inline" set:html={customParts.sins || customParts.danger} />
										)}
										{block._key === "k5" && customParts.greenAlertFmc && customParts.sins && (
											<div class="custom-html-inline" set:html={customParts.sins} />
										)}
										{block._key === "k3" && customParts.gapHs && (
											<div class="custom-html-inline" set:html={customParts.gapHs} />
										)}
										{block._key === "k3" && customParts.explainersPy && (
											<div class="custom-html-inline" set:html={customParts.explainersPy} />
										)}
										{block._key === "k3" && customParts.brainMap && (
											<div class="custom-html-inline" set:html={customParts.brainMap} />
										)}
										{block._key === "k4" && customParts.manifestoSd && (
											<div class="custom-html-inline" set:html={customParts.manifestoSd} />
										)}
										{block._key === "k4" && customParts.attackChart && !customParts.manifestoSd && (
											<div class="custom-html-inline" set:html={customParts.attackChart} />
										)}
										{block._key === "k5" && customParts.questions && !customParts.questionsHs && (
											<div class="custom-html-inline" set:html={customParts.questions} />
										)}
										{block._key === "k6" && customParts.bottlenecksPy && (
											<div class="custom-html-inline" set:html={customParts.bottlenecksPy} />
										)}
										{block._key === "k6" && (customParts.chart || customParts.traffic) && (
											<div class="custom-html-inline" set:html={customParts.chart || customParts.traffic} />
										)}
										{block._key === "k8" && (customParts.compareTable || customParts.pvTable) && (
											<div class="custom-html-inline" set:html={customParts.compareTable || customParts.pvTable} />
										)}
										{block._key === "k10" && customParts.models && !customParts.modelsF40 && (
											<div class="custom-html-inline" set:html={customParts.models} />
										)}
										{block._key === "k14" && customParts.emdashBadge && (
											<div class="custom-html-inline" set:html={customParts.emdashBadge} />
										)}
										{block._key === "k10" && customParts.phases && !customParts.modelsF40 && (
											<div class="custom-html-inline" set:html={customParts.phases} />
										)}
										{block._key === "k10" && customParts.revProjection && (
											<div class="custom-html-inline" set:html={customParts.revProjection} />
										)}
										{block._key === "k12" && customParts.impactPy && (
											<div class="custom-html-inline" set:html={customParts.impactPy} />
										)}
										{block._key === "k11" && customParts.opexChartSd && (
											<div class="custom-html-inline" set:html={customParts.opexChartSd} />
										)}
										{block._key === "k11" && customParts.costGridSd && (
											<div class="custom-html-inline" set:html={customParts.costGridSd} />
										)}
										{block._key === "k11" && customParts.adopcionSd && (
											<div class="custom-html-inline" set:html={customParts.adopcionSd} />
										)}
										{block._key === "k11" && customParts.revenueChart && !customParts.costGridSd && (
											<div class="custom-html-inline" set:html={customParts.revenueChart} />
										)}
										{block._key === "k13" && customParts.featuresHs && (
											<div class="custom-html-inline" set:html={customParts.featuresHs} />
										)}
										{block._key === "k13" && customParts.regionalSd && (
											<div class="custom-html-inline" set:html={customParts.regionalSd} />
										)}
										{block._key === "k13" && customParts.steps && !customParts.regionalSd && (
											<div class="custom-html-inline" set:html={customParts.steps} />
										)}
										{block._key === "k15" && customParts.questionsHs && (
											<div class="custom-html-inline" set:html={customParts.questionsHs} />
										)}
										{block._key === "k16" && customParts.terminal && (
											<div class="custom-html-inline" set:html={customParts.terminal} />
										)}
										{block._key === "k21" && customParts.seoAeo && (
											<div class="custom-html-inline" set:html={customParts.seoAeo} />
										)}
									</>
								);
							})
						: <PortableText value={contentBlocks} />
				}
				{
					customParts?.cta && (
						<div class="custom-html-inline" set:html={customParts.cta} />
					)
				}
				{
					!customParts && post.data.custom_html && (
						<div class="custom-html-blocks" set:html={post.data.custom_html} />
					)
				}
			</div>
		</div>
	</article>

	{
		otherPostsWithTags.length > 0 && (
			<section class="more-posts">
				<div class="more-inner">
					<h2 class="more-title">Seguir leyendo</h2>
					<div class="more-grid">
						{otherPostsWithTags.map(({ post: p, tags: postTags }) => (
								<PostCard
									title={p.data.title}
									excerpt={p.data.excerpt}
									featuredImage={p.data.featured_image}
									href={`/posts/${p.id}`}
									date={p.data.publishedAt ?? undefined}
									readingTime={getReadingTime(p.data.content)}
									tags={postTags.map((t) => ({ slug: t.slug, label: t.label }))}
									viewCount={relatedViewCounts.get(p.data.id)}
									reveal
								/>
							)
						)}
					</div>
				</div>
			</section>
		)
	}

	<script>
		const articleContent = document.querySelector(".article-content");
		if (articleContent) {
			articleContent.querySelectorAll("p").forEach((p) => {
				const text = (p.textContent ?? "").trim();
				if (text.startsWith("⚡")) p.classList.add("callout-block");
				if (text.startsWith("—")) p.classList.add("stat-line");
			});
		}
	</script>
	<RevealOnView />
</Base>

<style>
	.article-cta {
		margin: var(--spacing-12) 0 var(--spacing-8);
		padding: var(--spacing-8) var(--spacing-10);
		background: linear-gradient(135deg, #fff4ec 0%, #fde8d0 100%);
		border-radius: 16px;
		border-left: 4px solid #E07020;
	}

	.article-cta h3 {
		font-size: var(--font-size-xl);
		font-weight: 700;
		color: #1a1a1a;
		margin: 0 0 var(--spacing-3);
	}

	.article-cta p {
		font-size: var(--font-size-base);
		color: #555;
		margin: 0 0 var(--spacing-6);
		line-height: var(--leading-relaxed);
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		padding: 10px 24px;
		background: linear-gradient(135deg, #E07020, #F59B20);
		color: #ffffff;
		font-weight: 600;
		font-size: var(--font-size-sm);
		border-radius: 9999px;
		text-decoration: none;
		box-shadow: 0 4px 16px rgba(224, 112, 32, 0.35);
		transition: transform 200ms ease, box-shadow 200ms ease;
	}

	.cta-button:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(224, 112, 32, 0.5);
	}
	/* Article container — single column */
	.article {
		max-width: 860px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.article-hero {
		margin: var(--spacing-16) 0;
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--color-surface);
	}

	.article-hero img {
		width: 100%;
		height: auto;
		max-height: 500px;
		object-fit: cover;
	}

	.article-inner {
		margin: var(--spacing-8) 0 var(--spacing-16);
	}

	.article-header {
		margin-bottom: var(--spacing-8);
	}

	.article-title {
		font-size: clamp(2rem, 5vw, var(--font-size-5xl));
		font-weight: 700;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-4);
	}

	.article-excerpt {
		background: #0B1F3A;
		color: white;
		font-style: italic;
		font-size: 1.1rem;
		line-height: 1.75;
		padding: 20px 28px;
		border-radius: 12px;
		margin: 16px 0 24px;
	}

	.article-counters {
		margin: 0 0 var(--spacing-8);
	}

	.custom-html-inline {
		margin: 0;
	}

	.article-meta-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
