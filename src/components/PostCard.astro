---
import type { MediaValue } from "emdash";
import { Image } from "emdash/ui";
import { formatViewCount } from "../utils/post-views";

interface Props {
	title: string;
	excerpt?: string;
	featuredImage?: MediaValue | string;
	href: string;
	date?: Date;
	readingTime?: number;
	tags?: Array<{ slug: string; label: string }>;
	viewCount?: number;
	author?: string;
	reveal?: boolean;
}

const {
	title,
	excerpt,
	featuredImage,
	href,
	date,
	readingTime,
	tags,
	viewCount,
	author,
	reveal = false,
} = Astro.props;

const isoDate = date ? date.toISOString().slice(0, 10) : undefined;
const formattedDate = date
	? date.toLocaleDateString("es-CL", {
			year: "numeric",
			month: "short",
			day: "numeric",
		})
	: null;

const gradientVariant =
	[...title].reduce((acc, ch) => acc + ch.charCodeAt(0), 0) % 3;
const primaryTag = tags?.[0];
const displayViews = viewCount ?? 0;
---

<article class:list={["post-card", reveal && "reveal"]}>
	<a href={href} class="card-link">
		<div class="card-media">
			{
				featuredImage ? (
					<div class="card-image">
						<Image image={featuredImage} />
					</div>
				) : (
					<div
						class:list={[
							"card-placeholder",
							`card-placeholder--${gradientVariant}`,
						]}
					/>
				)
			}
			{
				primaryTag && (
					<span class="card-tag-pill">{primaryTag.label}</span>
				)
			}
		</div>
		<div class="card-body">
			<h2 class="card-title">{title}</h2>
			{
				tags && tags.length > 0 && (
					<div class="card-hashtags">
						{tags.slice(0, 3).map((tag) => (
							<span class="card-hashtag">#{tag.label}</span>
						))}
					</div>
				)
			}
			{excerpt && <p class="card-excerpt">{excerpt}</p>}
			<div class="card-meta-row">
				{
					author && (
						<span class="card-author">{author}</span>
					)
				}
				{
					formattedDate && isoDate && (
						<time class="card-date" datetime={isoDate}>
							{formattedDate}
						</time>
					)
				}
				{
					readingTime != null && readingTime > 0 && (
						<span class="card-read" aria-label={`${readingTime} minutos de lectura`}>
							<span aria-hidden="true">⏱</span>
							{readingTime}
						</span>
					)
				}
				<span class="card-views" aria-label={`${formatViewCount(displayViews)} vistas`}>
					<span aria-hidden="true">👁</span>
					{formatViewCount(displayViews)}
				</span>
			</div>
		</div>
	</a>
	{
		tags && tags.length > 1 && (
			<div class="card-tags-extra">
				{tags.slice(1, 3).map((tag) => (
					<a href={`/tag/${tag.slug}`} class="card-tag-link">
						{tag.label}
					</a>
				))}
			</div>
		)
	}
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		background: var(--color-bg);
		border: 1px solid var(--color-border-subtle);
		border-radius: 1.5rem;
		overflow: hidden;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
		transition:
			box-shadow var(--transition-base),
			transform var(--transition-base),
			border-color var(--transition-fast);
	}

	.post-card:hover {
		border-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
		box-shadow: 0 12px 40px
			color-mix(in srgb, var(--color-accent) 18%, rgba(15, 23, 42, 0.12));
		transform: translateY(-2px);
	}

	.post-card.reveal {
		opacity: 0;
		transform: translateY(14px);
	}

	.post-card.reveal.is-visible {
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity 360ms ease,
			transform 360ms ease,
			box-shadow var(--transition-base),
			border-color var(--transition-fast);
	}

	.card-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.card-media {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--color-surface);
	}

	.card-image {
		width: 100%;
		height: 100%;
	}

	.card-image :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}

	.post-card:hover .card-image :global(img) {
		transform: scale(1.03);
	}

	.card-placeholder {
		width: 100%;
		height: 100%;
		position: relative;
	}

	.card-placeholder::after {
		content: "";
		position: absolute;
		inset: 0;
		opacity: 0.22;
		background-image: radial-gradient(
			circle at 30% 30%,
			currentColor 1px,
			transparent 0
		);
		background-size: 20px 20px;
		pointer-events: none;
	}

	.card-placeholder--0 {
		color: var(--color-text);
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--color-accent) 35%, transparent),
			color-mix(in srgb, var(--color-accent) 55%, #ff8a64)
		);
	}

	.card-placeholder--1 {
		color: var(--color-text);
		background: linear-gradient(
			135deg,
			rgba(59, 130, 246, 0.35),
			rgba(30, 41, 59, 0.5)
		);
	}

	.card-placeholder--2 {
		color: var(--color-text);
		background: linear-gradient(
			135deg,
			rgba(34, 197, 94, 0.3),
			rgba(59, 130, 246, 0.38)
		);
	}

	.card-tag-pill {
		position: absolute;
		top: var(--spacing-4);
		left: var(--spacing-4);
		z-index: 1;
		display: inline-block;
		padding: 0.35rem 0.75rem;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-on-accent);
		background: var(--color-accent);
		border-radius: 9999px;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
		transition: background var(--transition-fast);
	}

	.post-card:hover .card-tag-pill {
		background: var(--color-accent-hover);
	}

	.card-body {
		padding: var(--spacing-6);
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		flex: 1;
	}

	.card-title {
		font-size: var(--font-size-xl);
		font-weight: 700;
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-snug);
		color: var(--color-text);
		margin: 0;
		transition: color var(--transition-fast);
	}

	.post-card:hover .card-title {
		color: var(--color-accent);
	}

	.card-hashtags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-1);
	}

	.card-hashtag {
		font-size: 11px;
		font-weight: 500;
		color: var(--color-accent);
		background: color-mix(in srgb, var(--color-accent) 10%, transparent);
		border-radius: 9999px;
		padding: 2px 8px;
	}

	.card-excerpt {
		font-size: var(--font-size-sm);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-meta-row {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--spacing-4);
		margin-top: auto;
		padding-top: var(--spacing-3);
		border-top: 1px solid var(--color-border-subtle);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.card-date {
		color: var(--color-muted);
	}

	.card-author {
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.card-read,
	.card-views {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}

	.card-views {
		color: var(--color-accent);
		font-weight: 500;
	}

	.card-meta-icon {
		width: 14px;
		height: 14px;
		flex-shrink: 0;
	}

	.card-tags-extra {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		padding: 0 var(--spacing-6) var(--spacing-5);
	}

	.card-tag-link {
		display: inline-block;
		padding: var(--tag-padding-y) var(--spacing-2);
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-text);
		background: color-mix(in srgb, var(--color-accent) 14%, transparent);
		border-radius: 9999px;
		text-decoration: none;
		transition:
			background var(--transition-fast),
			color var(--transition-fast);
	}

	.card-tag-link:hover {
		background: color-mix(in srgb, var(--color-accent) 26%, transparent);
		color: var(--color-accent-hover);
	}

	@media (prefers-reduced-motion: reduce) {
		.post-card,
		.post-card:hover,
		.post-card.reveal,
		.post-card.reveal.is-visible {
			transition: none;
			transform: none;
		}

		.post-card.reveal,
		.post-card.reveal.is-visible {
			opacity: 1;
		}

		.post-card:hover .card-image :global(img) {
			transform: none;
		}
	}
</style>
