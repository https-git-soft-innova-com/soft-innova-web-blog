---
import type { MediaValue } from "emdash";
import { Image } from "emdash/ui";

interface Props {
	title: string;
	excerpt?: string;
	featuredImage?: MediaValue | string;
	href: string;
	date?: Date;
	readingTime?: number;
	tags?: Array<{ slug: string; label: string }>;
}

const { title, excerpt, featuredImage, href, date, readingTime, tags } =
	Astro.props;

const isoDate = date ? date.toISOString().slice(0, 10) : undefined;
const formattedDate = date
	? date.toLocaleDateString("es-CL", {
			year: "numeric",
			month: "short",
			day: "numeric",
		})
	: null;

const gradientVariant =
	[...title].reduce((acc, ch) => acc + ch.charCodeAt(0), 0) % 3;
const primaryTag = tags?.[0];
---

<article class="post-card">
	<a href={href} class="card-link">
		<div class="card-media">
			{
				featuredImage ? (
					<div class="card-image">
						<Image image={featuredImage} />
					</div>
				) : (
					<div class:list={["card-placeholder", `card-placeholder--${gradientVariant}`]} />
				)
			}
			{
				primaryTag && (
					<span class="card-tag-pill">{primaryTag.label}</span>
				)
			}
		</div>
		<div class="card-body">
			<h2 class="card-title">{title}</h2>
			{excerpt && <p class="card-excerpt">{excerpt}</p>}
			<div class="card-meta-row">
				{
					formattedDate && isoDate && (
						<time class="card-date" datetime={isoDate}>
							{formattedDate}
						</time>
					)
				}
				{
					readingTime != null && readingTime > 0 && (
						<span class="card-read">
							<svg
								class="card-read-icon"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<circle cx="12" cy="12" r="10"></circle>
								<path d="M12 6v6l4 2"></path>
							</svg>
							{readingTime} min
						</span>
					)
				}
			</div>
		</div>
	</a>
	{
		tags && tags.length > 1 && (
			<div class="card-tags-extra">
				{tags.slice(1, 3).map((tag) => (
					<a href={`/tag/${tag.slug}`} class="card-tag-link">
						{tag.label}
					</a>
				))}
			</div>
		)
	}
</article>

<style>
	.post-card {
		--brand-orange: #f5a623;
		--card-navy: #1a1a2e;
		--card-muted: #64748b;
		display: flex;
		flex-direction: column;
		background: #fff;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 1.5rem;
		overflow: hidden;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
		transition:
			box-shadow 200ms ease,
			transform 200ms ease;
	}

	.post-card:hover {
		box-shadow: 0 12px 40px rgba(15, 23, 42, 0.12);
		transform: translateY(-2px);
	}

	.card-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.card-media {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: #f1f5f9;
	}

	.card-image {
		width: 100%;
		height: 100%;
	}

	.card-image :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}

	.post-card:hover .card-image :global(img) {
		transform: scale(1.03);
	}

	.card-placeholder {
		width: 100%;
		height: 100%;
		position: relative;
	}

	.card-placeholder::after {
		content: "";
		position: absolute;
		inset: 0;
		opacity: 0.22;
		background-image: radial-gradient(
			circle at 30% 30%,
			currentColor 1px,
			transparent 0
		);
		background-size: 20px 20px;
		pointer-events: none;
	}

	.card-placeholder--0 {
		color: #1a1a2e;
		background: linear-gradient(
			135deg,
			rgba(245, 166, 35, 0.35),
			rgba(255, 138, 100, 0.45)
		);
	}

	.card-placeholder--1 {
		color: #1a1a2e;
		background: linear-gradient(
			135deg,
			rgba(59, 130, 246, 0.35),
			rgba(30, 41, 59, 0.5)
		);
	}

	.card-placeholder--2 {
		color: #1a1a2e;
		background: linear-gradient(
			135deg,
			rgba(34, 197, 94, 0.3),
			rgba(59, 130, 246, 0.38)
		);
	}

	.card-tag-pill {
		position: absolute;
		top: var(--spacing-4);
		left: var(--spacing-4);
		z-index: 1;
		display: inline-block;
		padding: 0.35rem 0.75rem;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #fff;
		background: var(--brand-orange);
		border-radius: 9999px;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
	}

	.card-body {
		padding: var(--spacing-6);
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		flex: 1;
	}

	.card-title {
		font-size: var(--font-size-xl);
		font-weight: 700;
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-snug);
		color: var(--card-navy);
		margin: 0;
		transition: color 200ms ease;
	}

	.post-card:hover .card-title {
		color: var(--brand-orange);
	}

	.card-excerpt {
		font-size: var(--font-size-sm);
		line-height: var(--leading-relaxed);
		color: var(--card-muted);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-meta-row {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--spacing-4);
		margin-top: auto;
		padding-top: var(--spacing-1);
		font-size: var(--font-size-xs);
		color: var(--card-muted);
	}

	.card-date {
		color: var(--card-muted);
	}

	.card-read {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--card-muted);
	}

	.card-read-icon {
		width: 14px;
		height: 14px;
		flex-shrink: 0;
	}

	.card-tags-extra {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		padding: 0 var(--spacing-6) var(--spacing-5);
	}

	.card-tag-link {
		display: inline-block;
		padding: var(--tag-padding-y) var(--spacing-2);
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--card-navy);
		background: rgba(245, 166, 35, 0.12);
		border-radius: 9999px;
		text-decoration: none;
		transition:
			background 200ms ease,
			color 200ms ease;
	}

	.card-tag-link:hover {
		background: rgba(245, 166, 35, 0.22);
		color: #c2780a;
	}

	@media (prefers-reduced-motion: reduce) {
		.post-card,
		.post-card:hover {
			transition: none;
			transform: none;
		}

		.post-card:hover .card-image :global(img) {
			transform: none;
		}
	}
</style>
